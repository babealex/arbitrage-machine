<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.arbitrage.machine</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/python3</string>
    <string>-m</string>
    <string>app.main</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/Shared/arbitrage-machine</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/Shared/arbitrage-machine/logs/launchd.out</string>
  <key>StandardErrorPath</key>
  <string>/Users/Shared/arbitrage-machine/logs/launchd.err</string>
</dict>
</plist>
